  "tokenColors": [
    {
      "scope": ["meta.paragraph", "markup.bold", "markup.italic", "markup.underline.link"],
      "settings": { "foreground": "#f6dcac" }
    },
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#134e5a", "fontStyle": "italic" }
    },
    {
      "scope": ["constant", "variable.language", "variable.other.constant", "support.constant"],
      "settings": { "foreground": "#f6dcac" }
    },
    {
      "scope": ["constant.numeric", "constant.other.color"],
      "settings": { "foreground": "#f6dcac" }
    },
    {
      "scope": ["constant.language", "constant.language.boolean", "constant.language.null"],
      "settings": { "foreground": "#f6dcac" }
    },
    {
      "scope": ["constant.character", "constant.character.escape"],
      "settings": { "foreground": "#8cbfb8" }
    },
    {
      "scope": ["entity", "entity.name"],
      "settings": { "foreground": "#faa968" }
    },
    {
      "scope": ["entity.name.function", "meta.function-call", "support.function", "entity.name.method"],
      "settings": { "foreground": "#faa968" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": { "foreground": "#3f8f8a" }
    },
    {
      "scope": ["entity.name.section", "entity.name.tag", "meta.tag"],
      "settings": { "foreground": "#f85525" }
    },
    {
      "scope": ["entity.other.attribute-name", "entity.other.attribute-name.id"],
      "settings": { "foreground": "#faa968" }
    },
    {
      "scope": ["entity.other.attribute-name.class.css"],
      "settings": { "foreground": "#e97b3c" }
    },
